/*
解题思路：
想象一下你穿越回了过去，手里有一份未来的股票价格表。你从左到右一天天看过去，脑子里只需要记住两件事：

历史最低价：从第一天到今天为止，我见过的最便宜的股票是多少钱？（这决定了我的最佳买入成本）。

最大利润：如果我今天把股票卖掉，我能赚多少钱？（今天的价格 - 历史最低价）。我需要把这个利润和之前算出的最大利润做个比较，保留更大的那个。

2. 手工模拟：prices = [7, 1, 5, 3, 6, 4]
我们准备两个变量：

min_price（最低买入价），初始值设为一个极大的数。

max_profit（最大利润），初始值设为 0。

第 1 天 (7)：目前最低价变成了 7。今天卖没利润（7 - 7 = 0）。最大利润 = 0。

第 2 天 (1)：哇！发现更低的价格了，最低价更新为 1。今天卖利润是 1 - 1 = 0。最大利润 = 0。

第 3 天 (5)：最低价还是 1。如果今天卖，利润是 5 - 1 = 4。比之前的 0 大，最大利润更新为 4。

第 4 天 (3)：最低价还是 1。如果今天卖，利润是 3 - 1 = 2。不如 4 大，最大利润还是 4。

第 5 天 (6)：最低价还是 1。如果今天卖，利润是 6 - 1 = 5。比之前的 4 大，最大利润更新为 5。

第 6 天 (4)：最低价还是 1。如果今天卖，利润是 4 - 1 = 3。最大利润保持为 5。

遍历结束，最高利润就是 5！（在第 2 天买入，第 5 天卖出）。

*/

//ai的代码
class Solution {
public:
    int maxProfit(vector<int>& prices) {
        // 记录遍历过程中的历史最低价格，初始设为整型最大值
        int min_price = INT_MAX; 
        // 记录最大利润，初始为 0（因为题目说如果不赚钱就返回 0）
        int max_profit = 0;      

        for (int price : prices) {
            // 1. 如果今天的价格比历史最低价还要低，更新历史最低价
            if (price < min_price) {
                min_price = price;
            } 
            // 2. 否则，如果今天卖出的利润，比之前算出来的最大利润还要高，就更新最大利润
            else if (price - min_price > max_profit) {
                max_profit = price - min_price;
            }
        }

        return max_profit;
    }
};


//我的代码     这段代码同时避免了同天买同天卖
class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int min_history = INT16_MAX;
        int max_profit = 0;


        for (int price : prices)
        {
            min_history = min(min_history, price);
            max_profit = max(max_profit,(price- min_history));
        }

        return max_profit;
    }
};
