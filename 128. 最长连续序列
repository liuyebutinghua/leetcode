//我的代码：
class Solution {
public:
    int longestConsecutive(vector<int>& nums) {
        unordered_map<int, int> hash;
        for (int& num : nums)
        {
            int pre_num = hash.find(num - 1) == hash.end() ? 0 : hash[num - 1];
            int back_num = hash.find(num + 1) == hash.end() ? 0 : hash[num + 1];

            if (hash.find(num) == hash.end())
            {
                hash[num] = pre_num + back_num + 1;
                hash[num - pre_num] = hash[num];
                hash[num + back_num] = hash[num];
            }
        }

        int max_length = 0;
        for (auto& has : hash)
        {
            max_length = max(max_length, has.second);
        }
        return max_length;

    }
};
