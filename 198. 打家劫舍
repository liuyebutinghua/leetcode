//ai的代码
#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    int rob(vector<int>& nums) {
        int n = nums.size();
        // 边界情况处理
        if (n == 0) return 0;
        if (n == 1) return nums[0];

        // 对应第 0 间房的最高收益
        int prev2 = nums[0]; 
        // 对应第 1 间房的最高收益（在第0间和第1间里挑大的）
        int prev1 = max(nums[0], nums[1]); 

        // 从第 2 间房开始往后走
        for (int i = 2; i < n; i++) {
            // 灵魂方程：当前最高收益 = max(不偷当前，偷当前)
            int current = max(prev1, prev2 + nums[i]);
            
            // 偷完这间后，所有人往前挪一步，准备去下一间房
            prev2 = prev1;
            prev1 = current;
        }

        // 走到街尾，prev1 就是最终的最高收益
        return prev1;
    }
};

//我的代码
class Solution {
public:
    int rob(vector<int>& nums) {
        int n = nums.size();
        if (n == 1) return nums[0];

        int pre_i_1 = max(nums[0],nums[1]);
        int pre_i_2 = nums[0];

        for (int i = 2; i < n; i++)
        {
            int current = max(pre_i_1, pre_i_2 + nums[i]);
            pre_i_2 = pre_i_1;
            pre_i_1 = current;

        }

        return pre_i_1;
    }
};


