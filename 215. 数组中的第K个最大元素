class Solution {
public:

    int quicksearch(vector<int>& nums, int left,int right,int targetindex)//递归
    {
        if (left == right)
        {
            return nums[left];
        }

        int l = left, r = right;
        int startindex = left;

        int pivotIndex = left + rand() % (right - left + 1);
        int pivot = nums[pivotIndex];

        while (startindex <= r)//快速排序
        {
            if (nums[startindex] < pivot)
            {
                swap(nums[startindex], nums[l]);
                startindex++;
                l++;
            }
            else if (nums[startindex] > pivot)
            {
                swap(nums[startindex], nums[r]);
                r--;
            }
            else
            {
                startindex++;
            }
        }


        if (targetindex >= l && targetindex <= r)
        {
            return nums[targetindex];
        }
        else if (targetindex < l)
        {
            return quicksearch(nums, left, l-1,targetindex);
        }
        else
        {
            return quicksearch(nums, r+1, right, targetindex);
        }


    }

    int findKthLargest(vector<int>& nums, int k) {
        int targetindex = nums.size() - k;//目标索引
        return quicksearch(nums,0, nums.size()-1, targetindex);
    }
};



//第二种方案
1. 核心思维：维护一个容量为 K 的“VIP 俱乐部”我们建立一个大小严格限制为 $k$ 的小顶堆（Min-Heap）。小顶堆的特点：最小的元素永远在最上面（堆顶）。逻辑：遍历数组，把元素依次扔进堆里。如果堆里的元素数量超过了 $k$ 个，我们就把堆顶（也就是当前堆里最小的那个元素）无情地踢出去。结果：遍历完整个数组后，堆里留下来的就是全数组最大的 $k$ 个元素。而此时的堆顶（这 $k$ 个元素里最小的那个），刚好就是全数组第 $k$ 大的元素！2. C++ 极简代码实现在 C++ 中，我们使用 priority_queue。注意，它默认是“大顶堆”，我们需要加点参数把它变成“小顶堆”。C++#include <vector>
#include <queue>

using namespace std;

class Solution {
public:
    int findKthLargest(vector<int>& nums, int k) {
        // 定义一个小顶堆（Min-Heap）
        // 参数1: 数据类型, 参数2: 底层容器, 参数3: 比较器（greater表示小顶堆）
        priority_queue<int, vector<int>, greater<int>> minHeap;

        for (int num : nums) {
            minHeap.push(num); // 新元素进入“VIP 俱乐部”
            
            // 如果俱乐部人数超标了（大于 k）
            if (minHeap.size() > k) {
                // 把最弱的（最小的，也就是堆顶元素）踢出去
                minHeap.pop(); 
            }
        }

        // 遍历结束后，堆里剩下的就是最大的 k 个数
        // 堆顶就是这 k 个数里最小的，即第 k 大的数
        return minHeap.top();
    }
};
