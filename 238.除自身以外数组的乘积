//我的代码：
class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int n = nums.size();
        vector<int> left_ji(n, 1);
        vector<int> right_ji(n, 1);

        for (int i = 1; i < n; i++)
        {
            left_ji[i] = left_ji[i - 1] * nums[i-1];
            right_ji[n - i - 1]= right_ji[n - i]* nums[n - i];
        }

        vector<int> result(n);
        for (int i = 0; i < n; i++)
        {
            result[i] = left_ji[i]* right_ji[i];
        }
        return result;
    }
};

/*
极致压缩空间复杂度：
但是！面试官看到你这么快写完，一定会笑眯眯地指着题目说明里的那句“进阶要求”问你：
“你能保证在 O(1) 的额外空间复杂度内完成这个题目吗？（作为返回结果的 result 数组不计入空间复杂度）”

解题方法：
思路点拨：极致榨干 result 数组
既然 result 数组不算作额外空间，那我们能不能直接把 result 当作你的 left_ji 来用？
等算完左边的乘积后，右边的乘积我们根本不需要一个完整的数组来存，只需要一个单纯的整型变量 R，从右往左像滚雪球一样边乘边更新 result 就可以了！
*/
//我的代码：
class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int n = nums.size();
        vector<int> left_ji(n, 1);

        int right_ji=1;
        for (int i = 1; i < n; i++)
        {
            left_ji[i] = left_ji[i - 1] * nums[i-1];
           
        }

  
        for (int i = n-1; i>=0; i--)
        {
            left_ji[i] = left_ji[i] * right_ji;
            right_ji = right_ji * nums[i];
        }
        return left_ji;
    }
};


