/*
这道题是名副其实的 Hard 级别，它不仅是面试场上的“大杀器”，更是检验你代码工程能力的“试金石”。
它要求你把“206. 反转链表”和“24. 两两交换链表中的节点”完美融合，并且还要处理极其复杂的边界断连问题。

准备好纸笔，我们现在就来拆解这台精密仪器的内部构造！

1. 终极拆解图：模块化“切香肠”战术
面对长长的链表，不要慌。我们的战术是：侦察、切断、翻转、缝合。

我们需要派出几个关键的指针来打配合：

dummy：无敌哨兵，雷打不动地保护着整个链表的头部。

pre（保镖）：永远站在即将要翻转的那 K 个节点的最前面。

end（侦察兵）：负责往前探路，数够 K 个节点。

start：要翻转的那 K 个节点的第一个节点（翻转后它会变成最后一个）。

nextGroup：下一组未处理节点的开头（翻转期间绝不能弄丢！）。

极其暴力的“四步手术法”：

侦察兵探路：让 end 从 pre 的位置往前走 K 步。如果还没走到 K 步就掉下悬崖（nullptr）了，说明剩下的节点不够 K 个，直接收工回家，什么都不用改！

物理切断（最危险的一步）：如果凑齐了 K 个，记下下一组的开头 nextGroup = end->next。然后手起刀落，把 end->next 设为 nullptr！此时，这 K 个节点变成了一个彻底独立的短链表！

关门翻转：直接呼叫你的老熟人——206题的“反转链表”函数，把这段独立的短链表整个掉个头！

伤口缝合：翻转完成后，原本的 start 变成了尾巴，原本的 end 变成了新头。

让保镖 pre->next 连上新头（end）。

让新尾巴 start->next 连上下一组的开头（nextGroup）。

最后，让保镖 pre 和侦察兵 end 都走到新尾巴 start 的位置，准备切割下一段香肠！

2. C++ 满分工业级神级代码
你看，只要把逻辑拆分好，再复杂的 Hard 题，写出来也像是一篇条理清晰的说明书。注意看里面对 reverse 辅助函数的完美调用：

C++
/**
 * Definition for singly-linked list.
 * struct ListNode {
 * int val;
 * ListNode *next;
 * ListNode() : val(0), next(nullptr) {}
 * ListNode(int x) : val(x), next(nullptr) {}
 * ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    // 你的绝活：反转孤立单链表的辅助函数（206题源码直接抄过来）
    ListNode* reverse(ListNode* head) {
        ListNode* pre = nullptr;
        ListNode* curr = head;
        while (curr != nullptr) {
            ListNode* next_temp = curr->next;
            curr->next = pre;
            pre = curr;
            curr = next_temp;
        }
        return pre;
    }

    ListNode* reverseKGroup(ListNode* head, int k) {
        // 1. 请出无敌哨兵 Dummy Node
        ListNode* dummy = new ListNode(0);
        dummy->next = head;
        
        // pre 和 end 一开始都和 dummy 站在一起
        ListNode* pre = dummy;
        ListNode* end = dummy;

        // 只要链表还没走到尽头，就继续尝试“切香肠”
        while (end->next != nullptr) {
            // 2. 侦察兵 end 往前走 K 步
            for (int i = 0; i < k && end != nullptr; i++) {
                end = end->next;
            }
            
            // 如果 end 变成空了，说明最后这段不够 K 个，绝对不能反转，直接跳出循环！
            if (end == nullptr) break;

            // 3. 记录关键节点，准备动刀
            ListNode* start = pre->next;          // 这 K 个节点的开头
            ListNode* nextGroup = end->next;      // 下一组的开头（留好后路）

            // 4. 手起刀落：彻底切断这 K 个节点与后面的联系
            end->next = nullptr;

            // 5. 关门翻转：调用辅助函数，翻转这 K 个节点
            // 翻转后，原来的 end 变成了新头，被 pre 接住
            pre->next = reverse(start);

            // 6. 伤口缝合：原来的 start 变成了新尾巴，让它接上刚才留好后路的 nextGroup
            start->next = nextGroup;

            // 7. 整体推进：保镖 pre 和侦察兵 end 都挪到新尾巴 start 的位置，准备下一轮
            pre = start;
            end = pre;
        }

        // 8. 拿到真正的头节点，释放 dummy，完美谢幕！
        ListNode* result = dummy->next;
        delete dummy;
        
        return result;
    }
};
3. 为什么面试官会给这段代码打满分？
时间复杂度：O(N)。侦察兵 end 把链表走了一遍，reverse 函数把节点又翻转了一遍。每个节点最多被访问两到三次，绝对的线性时间！

空间复杂度：绝对的 O(1)。全场依然只有几个孤立的指针在飞舞，这就是原汁原味的“原地修改”！

极致的工程素养：将复杂的逻辑拆分成了主函数和 reverse 辅助函数（高内聚低耦合），边界条件处理得滴水不漏。

*/

// 我的代码：
class Solution {
    
public:
    ListNode* reserve(ListNode* head)
    {
        ListNode* pre = nullptr;
        ListNode* curr = head;

        while (curr!= nullptr)
        {
            ListNode* curr_next = curr->next;
            curr->next = pre;
            pre = curr;
            curr = curr_next;
        }
        return pre;
    }

    ListNode* reverseKGroup(ListNode* head, int k) {
        ListNode* dummy = new ListNode(0);
        dummy->next = head;

        ListNode* pre = dummy;//前一个
        ListNode* end = dummy;//尾一个


        while (end->next != nullptr)
        {
            for (int i = 0; i < k&& end!= nullptr; i++)
            {
                end = end->next;
            }

            if (end == nullptr) break;

            ListNode* start = pre->next;

            ListNode* nextgroup = end->next;
            end->next = nullptr;

            pre->next = reserve(start);

            start->next = nextgroup;

            pre = start;
            end = start;

        }


        ListNode* result = dummy->next;
        delete dummy;
        return result;

    }
};




