class MedianFinder {
    priority_queue<int> firstHalf;
    priority_queue<int, vector<int>, greater<int>> secondHalf;
public:
    MedianFinder() {
        
    }
    
    void addNum(int num) {
        if(firstHalf.empty() || firstHalf.top() >= num) {
            firstHalf.push(num);
        }
        else {
            secondHalf.push(num);
        }

        if(firstHalf.size() > secondHalf.size() + 1) {
            int tmp = firstHalf.top();
            firstHalf.pop();
            secondHalf.push(tmp);
        }

        if(secondHalf.size() > firstHalf.size() + 1) {
            int tmp = secondHalf.top();
            secondHalf.pop();
            firstHalf.push(tmp);
        }
    }
    
    double findMedian() {
        if((firstHalf.size() + secondHalf.size()) % 2) {
            return firstHalf.size() > secondHalf.size()? firstHalf.top(): secondHalf.top();
        }
        else {
            return (firstHalf.top() + secondHalf.top()) / 2.0;
        }
    }
};


/方法2的解析

1. 明确两个堆的“人设”firstHalf（大顶堆）：它是**“较小数字阵营”**。它的堆顶是这个阵营里最大的数（即靠近中间的数）。secondHalf（小顶堆）：它是**“较大数字阵营”**。它的堆顶是这个阵营里最小的数（即靠近中间的数）。2. addNum 的核心逻辑：分阵营 + 削峰填谷当一个新数字 num 过来时，代码分两步走：第一步：你是小个子还是大个子？（分配阵营）C++if(firstHalf.empty() || firstHalf.top() >= num) {
    firstHalf.push(num);
}
else {
    secondHalf.push(num);
}
如果 firstHalf 是空的，或者新来的数字比“小个子阵营”里的最高个子（firstHalf.top()）还要矮/一样高 $\rightarrow$ 毫无疑问，你属于小个子阵营，去 firstHalf。否则（新数字比小个子阵营的最高个子还高） $\rightarrow$ 那你就是大个子，去 secondHalf。第二步：削峰填谷（维护两边人数平衡）阵营分好后，可能会出现一个问题：某一边的人数比另一边多太多了！由于我们要找中位数，两边的人数差绝对不能超过 1。C++// 如果第一半区人太多了（比第二半区多 2 个或以上）
if(firstHalf.size() > secondHalf.size() + 1) {
    int tmp = firstHalf.top(); // 把小个子阵营里最高的那个抽出来
    firstHalf.pop();
    secondHalf.push(tmp);      // 调剂给大个子阵营
}
// 反之，如果第二半区人太多了
if(secondHalf.size() > firstHalf.size() + 1) {
    int tmp = secondHalf.top(); // 把大个子阵营里最矮的那个抽出来
    secondHalf.pop();
    firstHalf.push(tmp);        // 调剂给小个子阵营
}
通过这两步“多退少补”，不管你怎么加数字，firstHalf 和 secondHalf 的人数差距永远被死死卡在 0 或者 1。3. findMedian 的核心逻辑：奇偶分发既然人数永远平衡（最多差 1 个），拿中位数就非常简单了。C++// (firstHalf.size() + secondHalf.size()) % 2 
// 如果总数是奇数（结果为 1，进入 if 分支）
if((firstHalf.size() + secondHalf.size()) % 2) {
    // 谁的人数多，中位数就在谁的堆顶
    return firstHalf.size() > secondHalf.size() ? firstHalf.top() : secondHalf.top();
}
// 如果总数是偶数（结果为 0，进入 else 分支）
else {
    // 两人人数一样多，中位数就是两边堆顶的平均值
    return (firstHalf.top() + secondHalf.top()) / 2.0;
}
总结与对比这种写法和我之前教的“过桥法”有什么区别呢？过桥法：不管三七二十一，先压入大顶堆，再弹给小顶堆，最后判断要不要弹回来。代码行数少，不用写条件判断，但每次插入必定要操作 2~3 次堆。你的这段代码：先用 if 瞄一眼栈顶，决定去哪个堆（1 次入堆操作）。然后如果失衡了，再做调剂（失衡时增加 2 次操作，不失衡就不做）。
