        {
            int left = 0;
            int right = tails.size();

            while (left < right)
            {
                int mid = left + (right - left) / 2;

                if (tails[mid] < num)
                {
                    left = mid + 1;
                }
                else
                {
                    right = mid;
                }

            }

            if (left == tails.size())
            {
                tails.push_back(num);
            }
            else
            {
                tails[left] = num;
            }


        }

        return tails.size();
    }
};





