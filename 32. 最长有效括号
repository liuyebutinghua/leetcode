//我的代码：
class Solution {
public:
    int longestValidParentheses(string s) {
        stack<int> st;
        st.push(-1);

        int max_length = 0;

        for (int i = 0; i < s.size(); i++)
        {
            if (s[i] == '(')
            {
                st.push(i);
            }
            else
            {
                st.pop();

                if (st.empty())
                {
                    st.push(i);//新的边界
                }
                else
                {
                    max_length = max(i - st.top(),max_length);

                }
            }
        }
        return max_length;
    }
};
