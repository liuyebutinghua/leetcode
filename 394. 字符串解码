//递归法  ai的代码
class Solution {
public:
    // 辅助递归函数
    // 注意：这里的 int& i 是传引用！这是整个算法的灵魂。
    string decode(const string& s, int& i) {
        string res = "";
        int num = 0;
        
        while (i < s.size()) {
            char c = s[i];
            
            if (isdigit(c)) {
                // 处理多位数字
                num = num * 10 + (c - '0');
                i++;
            } 
            else if (isalpha(c)) {
                // 处理字母
                res += c;
                i++;
            } 
            else if (c == '[') {
                // 遇到 '['，开启子世界
                i++; // 跳过 '['
                
                // 魔法发生的地方：递归调用，去要括号里的解析结果
                string subStr = decode(s, i);
                
                // 拿到子世界的结果后，放大 num 倍拼接到当前世界
                while (num > 0) {
                    res += subStr;
                    num--;
                }
                
                // 注意：由于内部的 decode 遇到 ']' 就会 return，
                // 所以当递归返回时，当前的 i 正好指在 ']' 上。
                // 我们需要把它跳过，继续解析外层后面的字符。
                i++; 
            } 
            else if (c == ']') {
                // 遇到 ']'，当前世界解析结束，带着成果返回给上一层
                return res; 
            }
        }
        
        return res;
    }

    string decodeString(string s) {
        int i = 0; // 全局进度条，从 0 开始
        return decode(s, i);
    }
};






