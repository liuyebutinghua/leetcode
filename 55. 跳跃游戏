/*
解题思路：
1.暴力解法
使用递归，强行运算，会超时


2.贪心算法 (Greedy)
这道题的终极满分做法，思维极其巧妙，被称为**“维护最远可达位置”**。

不要去纠结“我这一步到底该跳 1 格还是跳 2 格”。我们换个视角：
我只要一直往前走，每次遇到一个新的格子，我就看看能不能借着这个格子，把我的“势力范围（最远可达位置）”再往外扩一点。

我们维护一个变量 max_reach，表示当前能到达的最远下标。

从左到右遍历数组。

如果当前遍历到的下标 i 已经超过了 max_reach，说明这里是一个断层，前面给的能量根本走不到这里，直接宣告失败（返回 false）。

否则，我们走到 i 这个格子，获取了 nums[i] 的跳跃能力。我们能到达的新边界就是 i + nums[i]。看看这个新边界能不能刷新我们的 max_reach。

如果在遍历过程中，max_reach 已经大于或等于终点下标了，直接宣告成功（返回 true）！


3.记忆搜索法
使用一个vector<int> memo;//备忘录     0  -未知，1  -能通过 -1  -表示不能通道

*/

//我的暴力解法（超时）
class Solution {
public:

    bool Jumpdsp(vector<int>& nums, int start, int target)
    {
        if (start >= target) return true;
        bool isTrue = false;
        if (nums[start] > 0)//可以继续前进
        {
            for (int i = 1; i <= nums[start]; i++)
            {
                isTrue = Jumpdsp(nums, start + i, target)|| isTrue;
            }
        }
        else if (nums[start] == 0)//无法继续前进
        {
            return false;
        }

        return isTrue;
    }


    bool canJump(vector<int>& nums) {
        int n = nums.size() - 1;
        return Jumpdsp(nums, 0, n);
    }
};


//ai的贪心算法
class Solution {
public:
    bool canJump(vector<int>& nums) {
        int max_reach = 0; // 当前能到达的最远下标
        int n = nums.size();

        for (int i = 0; i < n; i++) {
            // 致命判断：如果连当前这个格子 i 都走不到，后面就更别想了
            if (i > max_reach) {
                return false;
            }

            // 走到 i 了，看看能不能刷新最远可达位置
            max_reach = max(max_reach, i + nums[i]);

            // 如果已经能摸到甚至超越终点了，提前下班！
            if (max_reach >= n - 1) {
                return true;
            }
        }

        return false;
    }
};


//我的贪心算法
class Solution {
public:
    bool canJump(vector<int>& nums) {
        int max_reach = 0;
        int n = nums.size();


        for (int i = 0; i < n; i++)
        {
            if (i > max_reach) return false;
            max_reach = max(max_reach,(i+ nums[i]));

            if (max_reach >= n - 1)
            {
                return true;
            }

        }
        return false;

    }
};


//3.记忆搜索法
class Solution {
public:
    vector<int> memo;//备忘录     0  -未知，1  -能通过 -1  -表示不能通道


    bool Jumpdsp(vector<int>& nums, int start, int target)
    {
        if (memo[start] != 0)//看看这个节点来过没
        {
            return memo[start] == 1;
        }

        if (start >= target) return true;

        if (nums[start] > 0)//可以继续前进
        {
            for (int i = 1; i <= nums[start]; i++)
            {
                if (Jumpdsp(nums, start + i, target))
                {
                    memo[start] = 1;
                    return true;
                }
            }
        }
        else if (nums[start] == 0)//无法继续前进
        {
            return false;
        }
        memo[start] = -1;
        return false;
    }


    bool canJump(vector<int>& nums) {
        int n = nums.size() - 1;
        // 初始化备忘录，大小和 nums 一样，默认全是 0（未知）
        memo = vector<int>(nums.size(), 0);

        // 终点本身当然是能通关的
        memo[n] = 1;
        return Jumpdsp(nums, 0, n);
    }
};
