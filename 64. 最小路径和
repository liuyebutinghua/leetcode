//我的代码：
class Solution {
public:
    int minPathSum(vector<vector<int>>& grid) {
        int m = grid.size();
        int n = grid[0].size();

        vector<int> dp(n, 0);
        dp[0] = grid[0][0];

        for (int i = 1; i < n; i++)
        {
            dp[i] = dp[i - 1] + grid[0][i];
        }

        for (int i = 1; i < m; i++)
        {
            for (int j = 0; j < n; j++)
            {
                if (j == 0) dp[j] = grid[i][j] + dp[j];
                else dp[j] = grid[i][j] + min(dp[j], dp[j - 1]);            
            }
        }

        return dp[n - 1];
    }
};
