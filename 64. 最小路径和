    int minPathSum(vector<vector<int>>& grid) {
        int m = grid.size();
        int n = grid[0].size();

        // 只开辟一个长度为 n 的一维数组！空间复杂度暴降到 O(n)
        vector<int> dp(n, 0);

        for (int i = 0; i < m; i++)
        {
            for (int j = 0; j < n; j++)
            {
                if (i == 0 && j == 0) {
                    dp[j] = grid[i][j]; // 起点
                }
