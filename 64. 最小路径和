                    // 第 0 行：只能从左边过来
                    dp[j] = grid[i][j] + dp[j - 1];
                }
                else if (j == 0) {
                    // 第 0 列：只能从上面下来（此时 dp[j] 里存的就是上面那一行的值！）
                    dp[j] = grid[i][j] + dp[j];
                }
                else {
                    // 普通格子：自己原来的值就是上面的花费，左边的值就是左边的花费
