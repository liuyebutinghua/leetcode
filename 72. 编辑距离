/*
如果你还记得上一题“最长公共子序列（LCS）”的二维表格，那你已经赢了一大半。这道题的框架和上一题完全一样，唯一的区别在于：当两个字符不一样时，我们的“惩罚机制”变丰富了。

1. 核心思维：把三种操作翻译成“查表格”
我们依然建一个多加一行的二维数组：dp[i][j] 表示把 word1 的前 i 个字符转换成 word2 的前 j 个字符，所需的最少操作数。

灵魂拷问（状态转移方程）：
当我们正在对比 word1 的第 i 个字符和 word2 的第 j 个字符时：

“喜相逢”（字符一模一样）：
比如 word1 是 "ab**c**"，word2 是 "xy**c**"。
既然最后一个字符一样，根本不需要任何操作！
我们直接“白嫖”前面的结果：

dp[i][j]=dp[i−1][j−1]
“话不投机”（字符不一样）：
比如 word1 是 "hors**e**"，word2 是 "ro**s**"。
这时候你有三种超能力（代价都是操作数 + 1），我们看看它们在表格里对应什么方向：

替换（Replace）：把 'e' 替换成 's'，它俩就匹配了。剩下的问题就变成了把 "hors" 变成 "ro"。对应查左上角：dp[i-1][j-1] + 1

删除（Delete）：觉得 'e' 太碍事，直接删掉。剩下的问题变成了把 "hors" 变成 "ros"。对应查正上方：dp[i-1][j] + 1

插入（Insert）：在 'e' 后面硬塞一个 's' 让它们匹配。剩下的问题变成了把 "horse" 变成 "ro"。对应查正左方：dp[i][j-1] + 1

作为一个理性的最优解寻找者，我们当然是把这三条路的报价都看一眼，然后选一个最便宜的！

dp[i][j]=min(dp[i−1][j−1],dp[i−1][j],dp[i][j−1])+1
2. 找准地基：处理“空字符串”的极限情况
和上一题一样，我们需要第 0 行和第 0 列来当垫背的，但这次它们的初始化不是全填 0 了！

第 0 列（j = 0）：意思是把 word1 变成空字符串。
如果 word1 有 3 个字符，变成空串唯一的办法就是删除 3 次。所以 dp[i][0]=i。

第 0 行（i = 0）：意思是把空字符串变成 word2。
如果 word2 有 3 个字符，唯一的办法就是插入 3 次。所以 dp[0][j]=j。

这两条边，就是我们整个算法坚不可摧的地基。

3. C++ 满分标准代码
顺着这个逻辑，代码简直是水到渠成：

C++
#include <vector>
#include <string>
#include <algorithm>

using namespace std;

class Solution {
public:
    int minDistance(string word1, string word2) {
        int m = word1.length();
        int n = word2.length();

        // 创建 (m+1) x (n+1) 的 DP 表格
        vector<vector<int>> dp(m + 1, vector<int>(n + 1, 0));

        // 1. 打地基：word1 变成空串，全靠删除
        for (int i = 0; i <= m; i++) {
            dp[i][0] = i;
        }
        
        // 1. 打地基：空串变成 word2，全靠插入
        for (int j = 0; j <= n; j++) {
            dp[0][j] = j;
        }

        // 2. 开始填表：依然是从左到右，从上到下
        for (int i = 1; i <= m; i++) {
            for (int j = 1; j <= n; j++) {
                // 如果字符相等，直接继承左上角的老大哥，不增加操作数
                if (word1[i - 1] == word2[j - 1]) {
                    dp[i][j] = dp[i - 1][j - 1];
                } 
                // 如果字符不等，在 替换、删除、插入 中挑一个最便宜的，加上本次的 1 步操作
                else {
                    dp[i][j] = min({dp[i - 1][j - 1], // 替换 (左上)
                                    dp[i - 1][j],     // 删除 (上方)
                                    dp[i][j - 1]})    // 插入 (左边)
                                    + 1;
                }
            }
        }

        // 终点就是我们想要的最少操作数
        return dp[m][n];
    }
};
4. 复杂度分析
时间复杂度：O(M×N)。两个 for 循环遍历整个二维表格。

空间复杂度：O(M×N)。开辟了一个二维数组。（同理，如果你愿意，也可以用两个一维数组交替滚动，压缩到 O(min(M,N))，但面试中写出二维绝对够拿 Offer 了）。

总结
从“跳跃游戏”的一维贪心，到“打家劫舍”的带选择 DP，再到“背包问题”的空间压缩，最后杀穿了这道最经典的“编辑距离”双字符串 DP……你这一路刷下来，动态规划的核心框架（找状态 -> 推方程 -> 打地基）已经深深印在你的肌肉记忆里了。

*/


//我的代码：
class Solution {
public:
    int minDistance(string word1, string word2) {
        int m = word1.size();
        int n = word2.size();

        vector<vector<int>> bp(m+1,vector<int>(n+1,0));

        for (int i = 0; i <= m; i++)
        {
            bp[i][0] = i;
        }

        for (int i = 0; i <= n; i++)
        {
            bp[0][i] = i;
        }


        for (int i = 1; i <= m; i++)
        {
            for (int j = 1; j <= n; j++)
            {
                if (word1[i - 1] == word2[j - 1])  //字符相同，不需要操作
                {
                    bp[i][j] = bp[i - 1][j - 1];
                }
                else//字符不同时，需要操作
                {
                    bp[i][j] = min({ bp[i - 1][j - 1], bp[i][j - 1], bp[i - 1][j] }) + 1;//bp[i-1][j-1]:替换  bp[i][j - 1]:添加   bp[i - 1][j]:删除    
                }


            }

        }

        return bp[m][n];
    }
};
