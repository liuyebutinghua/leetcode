//m+n的解题代码：
class Solution {
public:
    void setZeroes(vector<vector<int>>& matrix) {
        int m = matrix.size();
        int n = matrix[0].size();

        vector<int> map(m + n, 0);

        for (int i = 0; i < m; i++)//标记要清零的行列
        {
            for (int j = 0; j < n; j++)
            {
                if (matrix[i][j] == 0)
                {
                    map[i] = 1;
                    map[m + j] = 1;
                }
            }
        }

        for (int i = 0; i < m ; i++)//行清零
        {
            for (int j = 0; j < n; j++)
            {
                if (map[i] == 1)
                {
                    matrix[i][j] = 0;
                }
            }
        }

        for (int i = m; i < m+n; i++)//列清零
        {
            for (int j = 0; j < m; j++)
            {
                if (map[i] == 1)
                {
                    matrix[j][i-m] = 0;
                }
            }
        }

    }
};
