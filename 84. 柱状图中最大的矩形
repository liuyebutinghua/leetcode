/*
解题思路：
1. 核心思维：固定高度，向两边延伸要在柱状图里找最大矩形，我们可以换个角度思考：
如果我强行以某一个柱子 $i$ 的高度 heights[i] 作为矩形的高度，这个矩形最宽能有多宽？
向左看：它能一直延伸，直到遇到一个比它矮的柱子才会被挡住。
向右看：它也能一直延伸，直到遇到一个比它矮的柱子才会被挡住。
也就是说，对于每一个柱子，我们只需要找到它左边第一个比它矮的柱子和右边第一个比它矮的柱子，就能算出以它为高度的最大矩形面积！

2. 为什么是单调栈？（与“每日温度”的对比）在“每日温度”里，栈里存的是“等待升温（找更大）”的日子，所以栈是从底到顶递减的。
在这道题里，我们要找的是“比当前矮”的柱子，所以栈里存的是“等待被矮柱子卡住”的柱子，栈是从底到顶递增的。
具体逻辑：我们把柱子的索引入栈，保持栈里的高度是递增的。如果当前遇到的柱子 i，比栈顶的柱子还要矮：
说明栈顶的柱子找到了它的右边界（就是当前的 i）！同时，因为栈是递增的，栈顶柱子底下的那个元素，
天然就是它的左边界！左右边界都找到了，就可以把栈顶柱子弹出来，
计算它的面积：面积 = 高度 * (右边界 - 左边界 - 1)。

3. 神仙技巧：首尾加 0（哨兵技巧）在写代码时，会有两个极其烦人的边界问题：
如果数组本来就是一直递增的（比如 [1, 2, 3]），所有的柱子都会呆在栈里弹不出来，
导致没法计算面积。如果弹栈弹到最后一个元素，栈空了，左边界去哪里找？破局之法：
在原数组的开头和结尾各加一个高度为 0 的虚拟柱子！尾部的 0：因为 0 比所有正数都小，
所以当遍历到最后这个 0 时，它会无情地把栈里所有剩余的柱子全部“挤”出来，强制计算面积。
头部的 0：永远垫在栈底，这样无论怎么弹栈，栈永远不会空，天然充当了所有最左侧柱子的“左边界”。


*/



//AI的代码
class Solution {
public:
    int largestRectangleArea(vector<int>& heights) {
        // 1. 首尾加 0 的神仙技巧
        vector<int> h(heights.size() + 2, 0);
        for (int i = 0; i < heights.size(); i++) {
            h[i + 1] = heights[i];
        }

        stack<int> st; // 单调栈，存放下标
        int maxArea = 0;

        // 2. 遍历新数组
        for (int i = 0; i < h.size(); i++) {
            // 如果当前柱子比栈顶柱子矮，说明栈顶柱子的“右边界”找到了！
            while (!st.empty() && h[i] < h[st.top()]) {
                // 取出栈顶柱子的高度
                int height = h[st.top()];
                st.pop();

                // 弹出后，新的栈顶就是它的“左边界”
                int left = st.top();
                int right = i; // 当前遍历到的位置就是“右边界”

                // 计算宽度：(右边界 - 左边界 - 1)
                int width = right - left - 1;

                // 更新最大面积
                maxArea = max(maxArea, height * width);
            }

            // 当前柱子处理完毕，入栈等待它的右边界
            st.push(i);
        }

        return maxArea;
    }
};

//我的代码
class Solution {
public:
    int largestRectangleArea(vector<int>& heights) {
        int n = heights.size();
        vector<int> newvector(n+2,0);

        for (int i = 0; i < n; i++)
        {
            newvector[i+1]= heights[i];
        }

        stack<int> st;
        int maxarea = 0;

        for (int i = 0; i < n + 2; i++)
        {
            while (!st.empty() && newvector[i]< newvector[st.top()])
            {
                int index = st.top();
                st.pop();

                maxarea = max(newvector[index] * (i - st.top()-1),maxarea);

            }
            st.push(i);
        }

        return maxarea;
    }
};
